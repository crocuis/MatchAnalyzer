DATABASE_URL='postgresql://user:password@host/neondb?sslmode=require&channel_binding=require'
R2_BUCKET=workflow-artifacts
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

LLM_PROVIDER=nvidia
LLM_PREDICTION_ADVISORY_ENABLED=0
LLM_REVIEW_ADVISORY_ENABLED=0
LLM_PREDICTION_MODEL=deepseek-ai/deepseek-v4-flash
LLM_REVIEW_MODEL=deepseek-ai/deepseek-v4-flash
LLM_REQUESTS_PER_MINUTE=40
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_COUNT=1
LLM_REVIEW_BACKFILL_LIMIT=100
LLM_REVIEW_BACKFILL_BATCH_SIZE=10
LLM_REVIEW_BACKFILL_ARCHIVE_ARTIFACTS=1
LLM_REVIEW_BACKFILL_PROGRESS=1
NVIDIA_API_KEY=your-nvidia-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_APP_URL=https://your-site.example
OPENROUTER_APP_TITLE=MatchAnalyzer

ODDS_API_KEY=your-odds-api
ODDS_API_IO_BOOKMAKERS=Bet365,Unibet
MARKET_CHECKPOINT_TYPES=T_MINUS_24H,T_MINUS_6H,T_MINUS_1H,LINEUP_CONFIRMED
BSD_API_KEY=your-bsd-api
BSD_LINEUP_LOOKAHEAD_HOURS=48
